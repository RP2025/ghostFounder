# Copy to .env and fill in. Never commit .env.
ANTHROPIC_API_KEY=sk-ant-...

# Model used for every agent call. Sonnet 5 is the sweet spot for a hackathon
# (fast + capable). Swap to claude-opus-4-8 for max quality, haiku for speed.
CLAUDE_MODEL=claude-sonnet-5

# Max tokens per agent response. Product Agent output is large, keep generous.
MAX_TOKENS=8192

# Loop guardrail: how many Product<->Business refinement passes before we stop.
MAX_LOOP_ITERATIONS=3

# The frontend origin allowed by CORS. Comma-separate for multiple.
FRONTEND_URL=http://localhost:3000
